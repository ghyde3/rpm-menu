# Copy to .env and fill in for local dev. Never commit the real .env.

# --- Database ---------------------------------------------------------
# Default (this file, as shipped): DATABASE_URL unset -> the app falls back
# to an in-process PGlite database stored under .data/pglite. Zero setup,
# no Docker required. (Requires next.config.ts's
# serverExternalPackages: ["@electric-sql/pglite"] to keep Turbopack from
# bundling it into the server runtime — already set in this repo.)
#
# For real Postgres instead (recommended before deploying, or if you want
# your dev DB to match production): uncomment DATABASE_URL below and run
# `docker compose up -d` first (host port 55432, to avoid colliding with
# other local Postgres instances).
# DATABASE_URL=postgres://postgres:postgres@localhost:55432/rpm_menu
# Set to "pglite" to force the PGlite fallback even when DATABASE_URL is set.
# DB_DRIVER=pglite
# Directory PGlite persists its data files to (gitignored).
# PGLITE_DATA_DIR=.data/pglite

# --- Auth (Better Auth) -------------------------------------------------
# Random 32+ byte secret used to sign sessions/cookies. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL Better Auth uses to build absolute callback/redirect URLs.
BETTER_AUTH_URL=http://localhost:3000

# --- App -----------------------------------------------------------------
# Public base URL of the app (used for QR codes, absolute links, MCP tool
# descriptions, etc).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Storage (StorageProvider, §3.1a) -------------------------------------
# Two drivers are implemented:
#   local (default, DEV ONLY) — writes processed images under .uploads/ and
#     serves them via GET /api/upload/files/... (src/lib/storage/local-disk-
#     driver.ts). Vercel's filesystem is ephemeral, so this does NOT work in
#     production — uploaded bytes would vanish on the next deploy/scale.
#   blob (PRODUCTION) — uploads each processed variant to a Vercel Blob store
#     (access: public) and persists the Blob's own public https URL
#     (src/lib/storage/vercel-blob-driver.ts). Requires BLOB_READ_WRITE_TOKEN.
# "r2" is still documented below as intended config shape but has NO driver
# module — STORAGE_DRIVER=r2 fails fast at startup (see interface.ts).
STORAGE_DRIVER=local
# Local-disk driver: directory uploaded/processed images are written to.
LOCAL_STORAGE_DIR=.uploads
# Vercel Blob driver (STORAGE_DRIVER=blob): the store's read/write token.
# Create a Blob store in the Vercel dashboard (Storage -> Blob) or with
# `vercel blob store add`; copy its token here. See docs/DEPLOY.md.
# Leave blank in local dev (STORAGE_DRIVER=local ignores it).
BLOB_READ_WRITE_TOKEN=
# R2 / S3-compatible driver config shape (NOT IMPLEMENTED — no R2 driver
# exists; STORAGE_DRIVER=r2 fails fast at startup. Kept as documented intent):
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# --- Seed / onboarding -----------------------------------------------------
# Credentials for the first owner account created by `npm run db:seed`.
SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_PASSWORD=change-me-before-seeding

# --- Production deploy (Railway Postgres + Vercel app) --------------------
# Full runbook: docs/DEPLOY.md. In PRODUCTION set these in the Vercel project's
# Environment Variables (NOT in any committed file):
#   DATABASE_URL          Railway Postgres connection string (postgres://...).
#                         Leave DB_DRIVER UNSET so the real pg driver is used
#                         (DB_DRIVER=pglite is a local-only fallback).
#   BETTER_AUTH_SECRET    32+ byte random secret (openssl rand -base64 32).
#   BETTER_AUTH_URL       the app's production URL (https://<app>.vercel.app).
#   NEXT_PUBLIC_APP_URL   same production URL (QR codes / absolute links).
#   STORAGE_DRIVER=blob   use the Vercel Blob driver in production.
#   BLOB_READ_WRITE_TOKEN the Vercel Blob store token (see above).
#   SEED_OWNER_EMAIL /    first owner account; used when running db:seed
#   SEED_OWNER_PASSWORD   against the Railway DB (see docs/DEPLOY.md).
# Migrations are NOT auto-run by Vercel — run `npm run db:migrate` (then
# `npm run db:seed`) against the Railway DATABASE_URL before/at first deploy.
