    "db:reset": "tsx --env-file=.env src/db/reset.ts",
    "mcp": "tsx --env-file=.env src/mcp/index.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "0.5.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-auth": "1.6.23",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "pg": "8.22.0",
    "qrcode": "1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.35.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8",
    "@types/qrcode": "^1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tsx": "4.23.0",
    "typescript": "^5",
    "vitest": "4.1.10"
  }
